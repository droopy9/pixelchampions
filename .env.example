# Pixel Champions — server-side wallet/token gating
# Copy this file to .env and fill in real values.
# If TOKEN_MINT_ADDRESS or SOLANA_RPC_URL is missing, the server runs in DEV MOCK MODE
# (signature + balance checks bypassed). DO NOT ship with mock mode enabled.

# The SPL token mint your race gates on.
TOKEN_MINT_ADDRESS=

# Minimum balance required to enter (defaults to 100000 if unset).
REQUIRED_TOKEN_AMOUNT=100000

# Solana RPC endpoint used for on-chain balance checks AND treasury payouts.
# Use a paid/private RPC in production — public mainnet RPC is rate-limited.
SOLANA_RPC_URL=

# Treasury wallet that pays race winners.
# Paste the contents of a Solana keypair JSON file (e.g.
# ~/.config/solana/treasury.json) — a 64-number array like
# [12, 34, 56, ...]. Leave empty for mock payouts.
TREASURY_SECRET_KEY_JSON=

# SOL paid to a winning real player (default 0.1).
WIN_REWARD_SOL=0.1
