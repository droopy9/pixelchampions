{
  "name": "pixel-champions",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "tsx watch server/game-server.ts",
    "dev": "concurrently -k -n SERVER,CLIENT -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "build": "tsc && vite build",
    "start": "tsx server/game-server.ts",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "express": "^5.2.1",
    "phaser": "^3.80.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  }
}
